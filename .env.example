# Backend Chatbot - Variáveis de Ambiente

# Porta do servidor
PORT=3001
HOST=127.0.0.1

# Ambiente
NODE_ENV=development

# URL do Ollama
OLLAMA_URL=http://127.0.0.1:11434

# Modelo de IA
MODEL=gemma3:4b

# URL do Frontend (Next.js)
FRONTEND_URL=http://localhost:3000

# System prompt customizado (opcional)
SYSTEM_PROMPT=Você é um assistente de IA prestativo. Responda em português do Brasil, de forma clara e objetiva. Seja conciso e direto nas respostas.

# WhatsApp Business Cloud API (opcional)
WHATSAPP_VERIFY_TOKEN=troque_por_um_token_seguro
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
